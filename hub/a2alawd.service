[Unit]
Description=A2Alaw Kernel Daemon
After=network.target redis-server.service
Wants=redis-server.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 -m a2alaw.hub.daemon
WorkingDirectory=/root
RuntimeDirectory=a2alaw
Environment=A2ALAW_HOST=127.0.0.1
Environment=A2ALAW_PORT=8741
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
